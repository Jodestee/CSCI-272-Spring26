// ============================================================
// WHAT THIS PROGRAM DOES:
// This program shows the most basic form of a C++ class.
// A class is like a blueprint — just like a blueprint for a house
// tells you how to build it, a class tells C++ how to build objects.
// Here we create a "Car" class and one Car object, then call its functions.
// ============================================================

// #include <iostream> → This line tells C++ to load the Input/Output library.
// Without this, we cannot use "std::cout" to print things to the screen.
#include <iostream>

// #include <string> → This line loads the string library.
// Without this, we cannot use "std::string" to store text (like brand names).
#include <string>

// ============================================================
// CLASS DEFINITION BEGINS HERE
// The keyword "class" tells C++ we are building a blueprint called "Car".
// The opening brace { marks the start of the class body.
// ============================================================
class Car {

// "private:" means these data members (variables) can ONLY be accessed
// from INSIDE the class. Code outside the class cannot read or change them directly.
// This is called ENCAPSULATION — hiding the internal details.
private:

    // std::string brand{"Volkswagen"}; → A text variable called "brand".
    // It is given a default value of "Volkswagen" using curly-brace initialization.
    // std::string means a sequence of characters (text).
    std::string brand{"Volkswagen"};

    // std::string model = "Polo"; → Another text variable called "model".
    // This uses = sign initialization instead of curly braces — both work the same way.
    std::string model = "Polo";

    // int year{2012}; → An integer (whole number) variable called "year".
    // It is set to 2012 by default.
    int year{2012};

// "public:" means these member functions (methods) CAN be accessed
// from OUTSIDE the class. This is how the outside world interacts with the Car.
public:

    // void startEngine() → A function (action) the car can do.
    // "void" means this function does NOT return any value — it just performs an action.
    // The () means it takes NO inputs (no parameters).
    // The { } is the body of the function — what happens when you call it.
    void startEngine() {
        // std::cout → This is used to print text to the screen.
        // << is the "insertion operator" — it sends data to the output stream.
        // "start engine" is the text we want to print.
        // std::endl → moves the cursor to a new line (like pressing Enter).
        std::cout << "start engine" << std::endl;
    }

    // void accelerate() → Another action the car can do.
    // Just like startEngine(), it takes no inputs and returns nothing.
    void accelerate() {
        // Prints "accelerate engine" to the screen followed by a new line.
        std::cout << "accelerate engine" << std::endl;
    }

// The closing }; marks the END of the class definition.
// IMPORTANT: The semicolon ; after } is REQUIRED for classes in C++.
};

// ============================================================
// MAIN FUNCTION — This is where the program starts running.
// Every C++ program must have exactly one main() function.
// "int" means this function returns an integer number when it finishes.
// ============================================================
int main() {

    // Car car1; → This creates a new Car OBJECT named "car1".
    // Think of it like using the Car blueprint to build one actual car.
    // This calls the default constructor (auto-generated since we didn't write one).
    // car1 will have: brand="Volkswagen", model="Polo", year=2012 (the defaults).
    Car car1;

    // car1.startEngine(); → This calls the startEngine() function ON the car1 object.
    // The dot (.) is how you access a member function of an object.
    // Output: "start engine"
    car1.startEngine();

    // car1.accelerate(); → This calls the accelerate() function ON the car1 object.
    // Output: "accelerate engine"
    car1.accelerate();

    // return 0; → This tells the operating system the program finished successfully.
    // 0 = success. Any other number usually means something went wrong.
    return 0;
}

