// ============================================================
// WHAT THIS PROGRAM DOES:
// This program demonstrates a "Person" class where the data members are
// declared as PUBLIC instead of private. This means they are directly
// accessible from outside the class.
// The class has one member function: introduce(), which prints a greeting.
// ============================================================

// Load the I/O library so we can use std::cout to print to the screen.
#include <iostream>

// Load the string library so we can use std::string for text variables.
#include <string>

// ============================================================
// CLASS DEFINITION: Person
// This class models a person with a name, age, and gender.
// ============================================================
class Person {

// "public:" here applies to BOTH the data members AND the member function.
// This means ANYTHING outside the class can read or modify name, age, gender directly.
// NOTE: Making data members public is less common in professional code because
// it breaks encapsulation, but it's valid and useful for learning.
public:

    // std::string name{"Maksi"}; → A text variable to store the person's name.
    // Default value is "Maksi" — any Person object created will start with this name.
    std::string name{"Maksi"};

    // int age{29}; → An integer variable for the person's age.
    // Default value is 29.
    int age{29};

    // char gender{'M'}; → A "char" is a SINGLE character variable.
    // It stores just one letter. Default is 'M' for Male.
    // Note: single characters use SINGLE quotes ' ' while strings use double quotes " ".
    char gender{'M'};

    // void introduce() → A member function that prints a greeting.
    // "void" = no return value. () = no parameters (takes nothing as input).
    void introduce() {

        // Print "Hello, I'm " followed by the value of name, then age info.
        // The << operator chains multiple outputs together on one line.
        std::cout << "Hello, I'm " << name << ". I'm " << age << " years old.";

        // if statement: checks if gender equals 'M' (Male).
        // The == is the COMPARISON operator (checks equality).
        // Single = would ASSIGN a value — very different! == COMPARES.
        if (gender == 'M') {
            // If gender is 'M', print this message and move to a new line.
            std::cout << " I'm a male." << std::endl;

        // else if: a second condition to check, only if the first was false.
        } else if (gender == 'F') {
            // If gender is 'F', print this message.
            std::cout << " I'm a female." << std::endl;

        // else: if NEITHER condition above was true, run this block.
        } else {
            std::cout << " Gender unspecified." << std::endl;
        }
        // The if/else if/else chain ends here. Only ONE branch runs.
    }

// End of class definition. The ; after } is mandatory for classes.
};

// ============================================================
// MAIN FUNCTION — Program execution starts here.
// ============================================================
int main() {

    // Person person1; → Creates an object called "person1" using the Person class.
    // Since no arguments are given, it uses default values:
    //   name = "Maksi", age = 29, gender = 'M'
    Person person1;

    // person1.introduce(); → Calls the introduce() function on person1.
    // Expected output: "Hello, I'm Maksi. I'm 29 years old. I'm a male."
    person1.introduce();

    // return 0 tells the OS the program completed successfully.
    return 0;
}

